                        s = s_;
                        u_i++;
                    }
                    if( data->control[ data->control_cursor ].textbox.cursor == u_i )
                        break;
                    if( !E_mem_Q_blk_I_remove( &data->control[ data->control_cursor ].textbox.text, s_start - data->control[ data->control_cursor ].textbox.text, l ))
                        break;
                    U_F( gui, draw );
                }else
                {   U u = E_keyboard_I_translate( queue_i );
                    if( ~u )
                    {   N l = E_text_Z_u_R_su_G(u);
                        if( !~l )
                            break;
                        Pc s = data->control[ data->control_cursor ].textbox.text;
                        N u_i = 0;
                        while( *s )
                        {   U u = ~0;
                            Pc s_ = E_text_Z_su_R_u( s, &u );
                            if( u_i == data->control[ data->control_cursor ].textbox.cursor )
                                break;
                            s = s_;
                            u_i++;
                        }
                        s = E_mem_Q_blk_I_insert( &data->control[ data->control_cursor ].textbox.text, s - data->control[ data->control_cursor ].textbox.text, l );
                        if( !s )
                            break;
                        E_text_Z_u_R_su( u, s );
                        if( data->control[ data->control_cursor ].textbox.visible_start < data->control[ data->control_cursor ].textbox.cursor )
                        {   S32 x_0 = x + data->control[ data->control_cursor ].x - data->scroll_x;
                            S32 x_ = x_0 + 1 + data->control[ data->control_cursor ].textbox.thickness + 1;
                            Pc s = data->control[ data->control_cursor ].textbox.text;
                            N u_i = 0;
                            Pc s_start;
                            B b = no;
                            O{  U u = ~0;
                                Pc s_ = E_text_Z_su_R_u( s, &u );
                                if( u_i < data->control[ data->control_cursor ].textbox.visible_start )
                                {   s = s_;
                                    u_i++;
                                    continue;
                                }
                                if( u_i == data->control[ data->control_cursor ].textbox.visible_start )
                                    s_start = s;
                                N32 font_i;
                                if( data->control[ data->control_cursor ].width <= x_ - x_0 + data->control[ data->control_cursor ].textbox.thickness + 1 + 1
                                || !E_font_T_print_u( data->control[ data->control_cursor ].width - ( x_ - x_0 ) - ( data->control[ data->control_cursor ].textbox.thickness + 1 + 1 ), data->control[ data->control_cursor ].textbox.thickness, &u, &font_i )
                                )
                                {   b = yes;
                                    break;
                                }
                                x_ += ( data->control[ data->control_cursor ].textbox.thickness + 1 ) * E_font_S_font.bitmap[ font_i ].width + data->control[ data->control_cursor ].textbox.thickness + 1;
                                if( u_i == data->control[ data->control_cursor ].textbox.cursor )
                                    break;
                                s = s_;
                                u_i++;
                            }
                            if(b)
                            {   s = s_start;
                                while( ++data->control[ data->control_cursor ].textbox.visible_start != data->control[ data->control_cursor ].textbox.cursor + 1 )
                                {   U u_ = ~0;
                                    Pc s_ = E_text_Z_su_R_u( s, &u_ );
                                    s = s_;
                                    N32 font_i;
                                    E_font_T_print_u( 0, data->control[ data->control_cursor ].textbox.thickness, &u_, &font_i );
                                    x_ -= ( data->control[ data->control_cursor ].textbox.thickness + 1 ) * E_font_S_font.bitmap[ font_i ].width + data->control[ data->control_cursor ].textbox.thickness + 1;
                                    if( data->control[ data->control_cursor ].width > x_ - x_0 + data->control[ data->control_cursor ].textbox.thickness + 1 + 1
                                    && E_font_T_print_u( data->control[ data->control_cursor ].width - ( x_ - x_0 ) - ( data->control[ data->control_cursor ].textbox.thickness + 1 + 1 ), data->control[ data->control_cursor ].textbox.thickness, &u, &font_i )
                                    )
                                        break;
                                }
