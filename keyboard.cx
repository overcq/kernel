#define E_keyboard_S_rw_timeout         1000
#define E_keyboard_S_queue_n            16
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
enum E_keyboard_Z_led
{ E_keyboard_Z_led_S_scroll_lock = 1 << 0
, E_keyboard_Z_led_S_num_lock = 1 << 1
, E_keyboard_Z_led_S_caps_lock = 1 << 2
};
enum E_keyboard_Z_meta
{ E_keyboard_Z_meta_S_shift = 1 << 0
, E_keyboard_Z_meta_S_ctrl = 1 << 1
, E_keyboard_Z_meta_S_alt = 1 << 2
, E_keyboard_Z_meta_S_alt_r = 1 << 3
, E_keyboard_Z_meta_S_logo = 1 << 4
};
//==============================================================================
struct E_keyboard_Z_key
{ N8 code;
  unsigned ex_1 :1;
  unsigned ex_2 :1;
  unsigned up   :1;
};
struct E_keyboard_Z_code_to_u
{ N8 code;
  U u;
};
//==============================================================================
_internal volatile N8 E_keyboard_S_reply;
_internal B E_keyboard_S_ex_1, E_keyboard_S_ex_2;
_internal B E_keyboard_S_prefix;
_internal volatile N8 E_keyboard_S_led_set, E_keyboard_S_led_set_changed_1;
_internal volatile B E_keyboard_S_led_set_changed_0, E_keyboard_S_queue_changed;
_private volatile struct E_keyboard_Z_key *E_keyboard_S_queue;
_private volatile N8 E_keyboard_S_queue_i;
_private volatile N8 E_keyboard_S_meta_set;
