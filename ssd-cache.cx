#define E_ssd_cache_Q_trim_S_list_max   ( 4096 / sizeof( struct E_sata_Z_dsm_range ))
//==============================================================================
struct E_ssd_cache_Z
{ N pba;
  N count;
  P data;
};
struct E_ssd_cache_Z_dirty
{ N pba;
  N count;
};
//==============================================================================
_private volatile N8 E_ssd_cache_S_lock;
