_private
N
E_ssd_cache_P_trim( I disc_id
, N pba
, N count
){  volatile N r = 0;
    struct E_disc_Z *disc = E_mem_Q_tab_R( E_disc_S, disc_id );
    if( !disc->sata_ahci.trim )
        return 0;
