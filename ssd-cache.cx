                    goto End_1;
                cache_i_last--;
            }
            if( !E_mem_Q_blk_I_remove( &disc->sata_ahci.ssd_cache, cache_i, cache_i_last - cache_i + 1 ))
            {   r = ~2;
                goto End;
            }
