    }
    if( column_i
    && ~window_data->selected_dir[ column_i - 1 ].selected_row
    && window_data->selected_dir[ column_i - 1 ].selected_row >= window_data->selected_dir[ column_i - 1 ].file_start_row
    && x_column + window_data->thickness + 1 < x + width
    )
    {   N32 width_ = J_min( x_column + window_data->column_width + window_data->column_margin_width, x + width ) - x_column;
        N32 height_ = J_min( 3 * width_ / 4, height );
        if( height_ > 1 )
        {   E_vga_I_draw_rect( x_column + window_data->thickness + 1, y + window_data->font_size + 1
            , width_, height_
            , 1
            , E_vga_R_video_color( 0x908b8b )
            );
        }
        Pc s = window_data->selected_dir[ column_i - 1 ].name[ window_data->selected_dir[ column_i - 1 ].selected_row ];
        N32 y_;
        if( x_column + window_data->thickness + 1 + width_ + window_data->thickness + 1 < x + width )
        {   y_ = y + window_data->font_size + 1;
            N32 column_width = x + width - ( x_column + window_data->thickness + 1 + width_ + window_data->thickness + 1 );
            do
            {   N32 clip_height = ( window_data->font_size + 1 ) * E_font_S_font.height;
                if( y_ + clip_height > y + height )
                    clip_height = y + height - y_;
                N32 x_ = x + width - column_width + window_data->thickness + 1;
                while( *s )
                {   U u;
                    Pc s_ = E_text_Z_su_R_u( s, &u );
                    N32 font_i;
                    if( column_width <= x_ - ( x + width - column_width ) + window_data->thickness + 1
                    || !E_font_T_print_u( column_width - ( x_ - ( x + width - column_width ) + window_data->thickness + 1 ), window_data->thickness, &u, &font_i )
                    )
                        break;
                    E_font_I_draw_u( font_i
                    , x_, y_
                    , y_, clip_height
                    , E_vga_S_text_color
                    , window_data->font_size
                    , window_data->thickness
                    );
                    s = s_;
                    x_ += ( window_data->thickness + 1 ) * E_font_S_font.bitmap[ font_i ].width + window_data->thickness + 1;
                }
                y_ += row_height;
            }while( *s
            && y_ < y + height
            && y_ < y + window_data->font_size + 1 + height_ + window_data->font_size + 1
            );
        }else
            y_ = y + window_data->font_size + 1 + height_ + window_data->font_size + 1;
        N32 column_width = x + width - x_column;
        do
        {   N32 clip_height = ( window_data->font_size + 1 ) * E_font_S_font.height;
            if( y_ + clip_height > y + height )
                clip_height = y + height - y_;
            N32 x_ = x_column + window_data->thickness + 1;
            while( *s )
            {   U u;
                Pc s_ = E_text_Z_su_R_u( s, &u );
                N32 font_i;
                if( column_width <= x_ - x_column + window_data->thickness + 1
                || !E_font_T_print_u( column_width - ( x_ - x_column + window_data->thickness + 1 ), window_data->thickness, &u, &font_i )
                )
                    break;
                E_font_I_draw_u( font_i
                , x_, y_
                , y_, clip_height
                , E_vga_S_text_color
                , window_data->font_size
                , window_data->thickness
                );
                s = s_;
                x_ += ( window_data->thickness + 1 ) * E_font_S_font.bitmap[ font_i ].width + window_data->thickness + 1;
            }
            y_ += row_height;
        }while( *s
        && y_ < y + height
        );
    }
    return 0;
}
_internal
void
E_window_files_I_mouse_move( I window_id
, N32 x
, N32 y
){  struct E_window_Q_window_Z *window = E_mem_Q_tab_R( E_windows_Q_desktop_S[ E_window_Q_desktop_S_current ].window, window_id );
    struct E_controls_Z_data *controls_data = window->controls_data;
    if( ~controls_data->control_cursor )
        return;
    X_A( gui, draw );
    struct E_window_files_Z_data *window_data = window->data;
    N32 column_width = window_data->column_width + window_data->column_margin_width;
    N column = window_data->dir_start + x / column_width;
    if( x % column_width == column_width - 1 )
        column = ~0;
    else if( ~column )
        if( column < window_data->selected_dir_n )
            column++;
        else
            column = ~0;
    else
        column = 0;
    if( ~column )
    {   N32 row_height = ( window_data->font_size + 1 ) * E_font_S_font.height + window_data->font_size + 1;
        N row = ( column ? window_data->selected_dir[ column - 1 ].row_start : window_data->disc_partition_row_start )
        + ( y > window_data->font_size + 1 ? ( y - ( window_data->font_size + 1 )) / row_height : 0 );
        if( row < ( column ? window_data->selected_dir[ column - 1 ].n : window_data->disc_partition_n ))
        {   if( window_data->pointer_row != row - ( column ? window_data->selected_dir[ column - 1 ].row_start : window_data->disc_partition_row_start ))
            {   window_data->pointer_row = row - ( column ? window_data->selected_dir[ column - 1 ].row_start : window_data->disc_partition_row_start );
                U_F( gui, draw );
            }
        }else if( window_data->pointer_row != ~0 )
        {   window_data->pointer_row = ~0;
            U_F( gui, draw );
        }
    }
    if( window_data->pointer_column != ( ~column && column ? column - ( window_data->dir_start + 1 ) : column ))
    {   if( !~window_data->pointer_column
        || window_data->pointer_column <= window_data->selected_dir_n // Jeśli po ewentualnym przewinięciu nie pozostało poza kolumnami.
        )
            U_F( gui, draw );
        window_data->pointer_column = column;
        if( ~column && column )
            window_data->pointer_column -= window_data->dir_start + 1;
    }
    if( ~window_data->pointer_column
    && ~window_data->pointer_row
    )
    {   N32 row_height = ( window_data->font_size + 1 ) * E_font_S_font.height + window_data->font_size + 1;
        N32 x = window->sized ? window->x + E_gui_Q_desktop_S_window_border_thickness : 0;
        N32 y = window->sized ? window->y + E_gui_Q_desktop_S_window_border_thickness : E_gui_Q_taskbar_S_height;
        N column_i = window_data->dir_start + 1 + window_data->pointer_column;
        N row_i = ( column_i
        ? window_data->selected_dir[ column_i - 1 ].row_start
        : window_data->disc_partition_row_start
        ) + window_data->pointer_row;
        N32 y_ = y + window_data->font_size + 1 + window_data->pointer_row * row_height;
        if( row_i < ( column_i ? window_data->selected_dir[ column_i - 1 ].n : window_data->disc_partition_n )) // Jeśli po ewentualnym przewinięciu nie pozostało poza kolumnami.
        {   B expand = column_i
            ? window_data->selected_dir[ column_i - 1 ].name_expand[ row_i ]
            : window_data->disc_partition[ row_i ].name_expand;
            if( expand
            && ( !column_i
              || column_i != window_data->selected_dir_n
              || row_i != window_data->selected_dir[ column_i - 1 ].selected_row
            ))
            {   Pc s_0 = column_i
                ? window_data->selected_dir[ column_i - 1 ].name[ row_i ]
                : window_data->disc_partition[ row_i ].name;
                N32 x_column = x + window_data->pointer_column * ( window_data->column_width + window_data->column_margin_width );
                N32 bubble_width = E_main_S_framebuffer.width - x_column;
                N32 x_ = x_column + window_data->thickness + 1;
                Pc s = s_0;
                while( *s )
                {   U u;
                    Pc s_ = E_text_Z_su_R_u( s, &u );
                    s = s_;
                    N32 font_i;
                    if( bubble_width <= x_ - x_column + window_data->thickness + 1
                    || !E_font_T_print_u( bubble_width - ( x_ - x_column + window_data->thickness + 1 ), window_data->thickness, &u, &font_i )
                    )
                        break;
                    x_ += ( window_data->thickness + 1 ) * E_font_S_font.bitmap[ font_i ].width + window_data->thickness + 1;
                }
                if( *s )
                {   bubble_width = E_main_S_framebuffer.width;
                    x_ = window_data->thickness + 1;
                    s = s_0;
                    while( *s )
                    {   U u;
                        Pc s_ = E_text_Z_su_R_u( s, &u );
                        s = s_;
                        N32 font_i;
                        if( bubble_width <= x_ + window_data->thickness + 1
                        || !E_font_T_print_u( bubble_width - ( x_ + window_data->thickness + 1 ), window_data->thickness, &u, &font_i )
                        )
                            break;
                        x_ += ( window_data->thickness + 1 ) * E_font_S_font.bitmap[ font_i ].width + window_data->thickness + 1;
                    }
                    x_ = E_main_S_framebuffer.width - x_;
                    E_gui_Q_bubble_S.width = E_main_S_framebuffer.width - x_;
                }else
                {   E_gui_Q_bubble_S.width = x_ - x_column;
                    x_ = x_column;
                }
                if( y_ + row_height > E_main_S_framebuffer.height )
                    y_ = E_main_S_framebuffer.height - row_height;
                y_ -= window_data->font_size + 1;
                if( E_gui_Q_bubble_S.text != s_0
                || E_gui_Q_bubble_S.x != x_
                || E_gui_Q_bubble_S.y != y_
                )
                {   E_gui_Q_bubble_S.x = x_;
                    E_gui_Q_bubble_S.y = y_;
                    E_gui_Q_bubble_S.height = window_data->font_size + 1 + row_height;
                    E_gui_Q_bubble_S.text = s_0;
                    E_gui_Q_bubble_S.custom_draw = no;
                    E_gui_Q_bubble_S.font_size = window_data->font_size;
                    E_gui_Q_bubble_S.thickness = window_data->thickness;
                    E_gui_Q_bubble_S.click = &E_window_files_Q_bubble_Q_expand_I_click;
                    E_gui_Q_bubble_S.window_id = window_id;
                    U_F( gui, draw );
                }
            }
        }
    }
    X_U( gui, draw );
}
_internal
N
E_window_files_I_click( I window_id
, N32 x
, N32 y
){  struct E_window_Q_window_Z *window = E_mem_Q_tab_R( E_windows_Q_desktop_S[ E_window_Q_desktop_S_current ].window, window_id );
    struct E_window_files_Z_data *window_data = window->data;
    struct E_controls_Z_data *controls_data = window->controls_data;
    if( !~window_data->pointer_column
    || ~controls_data->control_cursor
    )
        return 0;
    N r = E_window_files_I_click_( window_id );
    if( K_error(r)
    && ~r
    )
    {   window_data->dir_start = ~0;
        window_data->pointer_column = ~0;
        N r_ = (N)E_mem_Q_blk_I_remove( &window_data->selected_dir, 0, window_data->selected_dir_n );
        if( K_error( r_ )
        || !r_
        )
        {   window->destroy = &E_window_files_W_error;
            r_ = E_windows_Q_window_W( E_window_Q_desktop_S_current, window_id );
            if( r > r_ )
                r = r_;
        }else
        {   window_data->selected_dir_n = 0;
            if( r == ~2 )
                r = ~1;
        }
    }
    return r;
}
_internal
void
E_window_files_I_wheel( I window_id
){  X_A( gui, draw );
    struct E_window_Q_window_Z *window = E_mem_Q_tab_R( E_windows_Q_desktop_S[ E_window_Q_desktop_S_current ].window, window_id );
    struct E_controls_Z_data *controls_data = window->controls_data;
    if( ~controls_data->control_cursor )
        return;
    struct E_window_files_Z_data *window_data = window->data;
    if( E_keyboard_S_meta_set == E_keyboard_Z_meta_S_ctrl )
    {   N dir_start;
        if( E_mouse_Q_wheel_S_count > 0 )
            if( window_data->dir_start + (N)E_mouse_Q_wheel_S_count < window_data->selected_dir_n )
                dir_start = window_data->dir_start + E_mouse_Q_wheel_S_count;
            else
                dir_start = window_data->selected_dir_n - 1;
        else
            if( window_data->dir_start + 1 >= (N)-E_mouse_Q_wheel_S_count )
                dir_start = window_data->dir_start + E_mouse_Q_wheel_S_count;
            else
                dir_start = ~0;
        if( window_data->dir_start != dir_start )
        {   window_data->dir_start = dir_start;
            window_data->pointer_row = ~0;
            U_F( gui, draw );
        }
    }else if( !E_keyboard_S_meta_set )
        if( ~window_data->pointer_column )
        {   N column_i = window_data->dir_start + 1 + window_data->pointer_column;
            if( !column_i )
            {   N selected_column_start;
                if( E_mouse_Q_wheel_S_count > 0 )
                    if( window_data->disc_partition_row_start + E_mouse_Q_wheel_S_count < window_data->disc_partition_n )
                        selected_column_start = window_data->disc_partition_row_start + E_mouse_Q_wheel_S_count;
                    else
                        selected_column_start = window_data->disc_partition_n - 1;
                else
                    if( window_data->disc_partition_row_start > -E_mouse_Q_wheel_S_count )
                        selected_column_start = window_data->disc_partition_row_start + E_mouse_Q_wheel_S_count;
                    else
                        selected_column_start = 0;
                if( window_data->disc_partition_row_start != selected_column_start )
                {   window_data->disc_partition_row_start = selected_column_start;
                    U_F( gui, draw );
                }
            }else
            {   N selected_column_start;
                if( E_mouse_Q_wheel_S_count > 0 )
                    if( window_data->selected_dir[ column_i - 1 ].row_start + E_mouse_Q_wheel_S_count < window_data->selected_dir[ column_i - 1 ].n )
                        selected_column_start = window_data->selected_dir[ column_i - 1 ].row_start + E_mouse_Q_wheel_S_count;
                    else
                        selected_column_start = window_data->selected_dir[ column_i - 1 ].n - 1;
                else
                    if( window_data->selected_dir[ column_i - 1 ].row_start > -E_mouse_Q_wheel_S_count )
                        selected_column_start = window_data->selected_dir[ column_i - 1 ].row_start + E_mouse_Q_wheel_S_count;
                    else
                        selected_column_start = 0;
                if( window_data->selected_dir[ column_i - 1 ].row_start != selected_column_start )
                {   window_data->selected_dir[ column_i - 1 ].row_start = selected_column_start;
                    U_F( gui, draw );
                }
            }
        }
    X_U( gui, draw );
}
