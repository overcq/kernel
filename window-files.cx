                    E_mem_Q_blk_I_remove( &window_data->selected_dir, column_i, 1 );
                    window_data->selected_dir_n = column_i;
                    return;
                }
                _0t_( window_data->selected_dir[ column_i ].name_expand, n_dir + n_file );
                window_data->selected_dir[ column_i ].file_start_row = n_dir;
                window_data->selected_dir[ column_i ].n = n_dir + n_file;
                window_data->selected_dir[ column_i ].row_start = ~0;
                window_data->selected_dir[ column_i ].selected_row = ~0;
                window_data->disc_partition_selected_row = row_i;
                window_data->selected_dir_n = column_i + 1;
            }else
            {   E_mem_Q_blk_I_remove( &window_data->selected_dir, column_i, window_data->selected_dir_n );
                window_data->selected_dir_n = column_i;
                window_data->disc_partition_selected_row = row_i;
            }
        }else
            return;
    }
    X_F( gui, draw );
}
_internal
void
E_window_files_Q_bubble_I_click(
  N32 x
, N32 y
){  struct E_window_Q_window_Z *window = E_mem_Q_tab_R( E_windows_Q_desktop_S[ E_window_Q_desktop_S_current ].window, E_gui_Q_bubble_S.window_id );
    E_window_files_I_click_(window);
    if( E_gui_Q_bubble_S.draw )
