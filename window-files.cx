_internal
N
E_window_files_W( N8 desktop_id
, I window_id
){  struct E_window_Q_window_Z *window = E_mem_Q_tab_R( E_windows_Q_desktop_S[ desktop_id ].window, window_id );
    struct E_window_files_Z_data *window_data = window->data;
    for_n( i, window_data->disc_partition_n )
    {   N r = W( window_data->disc_partition[i].name );
        if(r)
            return r;
    }
    N r = W( window_data->disc_partition );
    if(r)
        return r;
    for_n_( i, window_data->selected_dir_n )
    {   r = W( window_data->selected_dir[i].uid );
        if(r)
            return r;
        for_n( j, window_data->selected_dir[i].n )
        {   r = W( window_data->selected_dir[i].name[j] );
            if(r)
                return r;
        }
        r = W( window_data->selected_dir[i].name );
        if(r)
            return r;
    }
    r = W( window_data->selected_dir );
    if(r)
        return r;
    return W( window->data );
}
_private
I
E_window_files_M( N8 desktop_id
){  struct E_window_files_Z_data *M_(data);
    if( !data )
        return ~0;
    data->disc_partition_n = 0;
    Mt_( data->disc_partition, data->disc_partition_n );
    if( !data->disc_partition )
    {   N r = W(data);
        return r ? ~1 : ~0;
    }
    data->selected_dir_n = 0;
    Mt_( data->selected_dir, data->selected_dir_n );
    if( !data->selected_dir )
    {   N r = W( data->disc_partition );
        if(r)
            return ~1;
        r = W(data);
        return r ? ~1 : ~0;
    }
    I window_id = E_windows_Q_window_M( desktop_id, "File browser", "OUX filesystem window", &E_window_files_I_draw, &E_window_files_I_mouse_move, &E_window_files_I_click, &E_window_files_I_wheel, &E_window_files_I_key, &E_window_files_W );
    if( window_id < 0 )
        return window_id;
    for_each( disc_id, E_disc_S, E_mem_Q_tab )
    {   struct E_disc_Z *disc = E_mem_Q_tab_R( E_disc_S, disc_id );
        for_n( partition_i, disc->partition_n )
        {   if( !E_mem_Q_blk_I_append( &data->disc_partition, 1 ))
            {   N r = E_windows_Q_window_W( desktop_id, window_id );
                return r ? r : ~0;
            }
            data->disc_partition[ data->disc_partition_n ].disc = disc_id;
            data->disc_partition[ data->disc_partition_n ].partition = partition_i;
            N l_1 = E_text_Z_n_N_s_G( disc_id, 10 );
            N l_2 = E_text_Z_n_N_s_G( partition_i, 10 );
            Pc s = M( l_1 + 1 + l_2 + 1 );
            if( !s )
            {   if( !E_mem_Q_blk_I_remove( &data->disc_partition, data->disc_partition_n, 1 ))
                    return ~2;
                N r = E_windows_Q_window_W( desktop_id, window_id );
                return r ? r : ~0;
            }
            s[ l_1 + 1 + l_2 ] = '\0';
            E_text_Z_n_N_s( s + l_1 + 1 + l_2, partition_i, 10 );
            s[ l_1 ] = ':';
