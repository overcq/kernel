_private
I
E_windows_Q_window_R_order_i( N8 desktop_id
, I window_id
){  for_i( window_i, E_mem_Q_tab_R_n( E_windows_Q_desktop_S[ desktop_id ].window ))
        if( E_windows_Q_desktop_S[ desktop_id ].order[ window_i ] == window_id )
