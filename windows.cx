_private
N
E_windows_Q_desktop_M( B on_end
){  if( (S8)( E_windows_Q_desktop_S_n + 1 ) < 0 )
        return ~0;
    N8 desktop_id;
    if( on_end )
    {   if( !E_mem_Q_blk_I_append( &E_windows_Q_desktop_S, 1 ))
            return ~0;
        desktop_id = E_windows_Q_desktop_S_n;
    }else
    {   if( !E_mem_Q_blk_I_prepend( &E_windows_Q_desktop_S, 1 ))
            return ~0;
        desktop_id = 0;
    }
    E_windows_Q_desktop_S_n++;
    E_windows_Q_desktop_S[ desktop_id ].window = E_mem_Q_tab_M( sizeof( struct E_window_Q_window_Z ), 0 );
    if( !E_windows_Q_desktop_S[ desktop_id ].window )
    {   Kp_( ~2, E_mem_Q_blk_I_remove( &E_windows_Q_desktop_S, desktop_id, 1 ));
        return ~0;
    }
    Mt_( E_windows_Q_desktop_S[ desktop_id ].order, 0 );
    if( !E_windows_Q_desktop_S[ desktop_id ].order )
    {   K_( ~2, E_mem_Q_tab_W( E_windows_Q_desktop_S[ desktop_id ].window ));
        Kp_( ~2, E_mem_Q_blk_I_remove( &E_windows_Q_desktop_S, desktop_id, 1 ));
        return ~0;
    }
    Mt_( E_windows_Q_desktop_S[ desktop_id ].stack, 0 );
    if( !E_windows_Q_desktop_S[ desktop_id ].stack )
    {   K_( ~2, W( E_windows_Q_desktop_S[ desktop_id ].order ));
        K_( ~2, E_mem_Q_tab_W( E_windows_Q_desktop_S[ desktop_id ].window ));
        Kp_( ~2, E_mem_Q_blk_I_remove( &E_windows_Q_desktop_S, desktop_id, 1 ));
        return ~0;
    }
    E_windows_Q_desktop_S[ desktop_id ].visible_button_start = 0;
    E_windows_Q_desktop_S[ desktop_id ].visible_buttons = 0;
    return 0;
}
_private
N
E_windows_Q_desktop_W( N8 desktop_id
){  if( desktop_id == E_window_Q_desktop_S_current )
        E_gui_Q_bubble_S.draw = 0;
    E_flow_I_cli();
    for_each( window_id, E_windows_Q_desktop_S[ desktop_id ].window, E_mem_Q_tab )
    {   struct E_window_Q_window_Z *window = E_mem_Q_tab_R( E_windows_Q_desktop_S[ desktop_id ].window, window_id );
        if( window->controls_data )
        {   N r = E_controls_W( desktop_id, window_id );
            if( (S)r < 0 )
            {   E_flow_I_sti();
                return r < ~2 ? r : ~2;
            }
        }
        if( window->destroy )
        {   N r = window->destroy( desktop_id, window_id );
            if( (S)r < 0 )
            {   E_flow_I_sti();
                return r < ~2 ? r : ~2;
            }
        }
        N r = W( window->description );
        if( (S)r < 0 )
        {   E_flow_I_sti();
            return r < ~2 ? r : ~2;
        }
        r = W( window->title );
        if( (S)r < 0 )
        {   E_flow_I_sti();
            return r < ~2 ? r : ~2;
        }
    }
    N r = W( E_windows_Q_desktop_S[ desktop_id ].stack );
    if( (S)r < 0 )
    {   E_flow_I_sti();
        return r < ~2 ? r : ~2;
    }
    r = W( E_windows_Q_desktop_S[ desktop_id ].order );
    if( (S)r < 0 )
    {   E_flow_I_sti();
        return r < ~2 ? r : ~2;
    }
    if( desktop_id == E_window_Q_desktop_S_current )
    {   E_gui_Q_desktop_S_window_moving = no;
        E_gui_Q_desktop_S_window_resizing_state = E_gui_Q_desktop_Z_window_resizing_state_S_none;
    }
    r = E_mem_Q_tab_W( E_windows_Q_desktop_S[ desktop_id ].window );
    if( (S)r < 0 )
    {   E_flow_I_sti();
        return r < ~2 ? r : ~2;
    }
    r = (N)E_mem_Q_blk_I_remove( &E_windows_Q_desktop_S, desktop_id, 1 );
    if( !~r
    || !r
    )
    {   if( !~r )
            Gk(E_mem_Q_blk_I_remove( &E_windows_Q_desktop_S, desktop_id, 1 ));
        E_flow_I_sti();
        return ~2;
    }
    E_windows_Q_desktop_S_n--;
    E_flow_I_sti();
    if( desktop_id == E_window_Q_desktop_S_current )
    {   E_gui_Q_taskbar_S_redraw = yes;
        X_F( gui, draw );
    }
    return 0;
}
