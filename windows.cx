_export
I
E_windows_Q_window_M( N8 desktop_id
, Pc title
, Pc description
, void ( *draw_proc )( I, N32, N32, N32, N32 )
, void ( *mouse_move )( I, N32, N32 )
, void ( *click )( I, N32, N32 )
, void ( *wheel )(I)
, void ( *key )( I, N )
, N ( *destroy )( N8, I )
){  E_flow_I_cli();
    I window_id = E_mem_Q_tab_I_add( E_windows_Q_desktop_S[ desktop_id ].window );
    if( window_id < 0 )
    {   E_flow_I_sti();
        return window_id;
    }
    I *order = E_mem_Q_blk_I_append( &E_windows_Q_desktop_S[ desktop_id ].order, 1 );
    if( !order )
    {   if( !~(N)order )
        {   Gk(E_mem_Q_blk_I_append( &E_windows_Q_desktop_S[ desktop_id ].order, 1 ));
            E_flow_I_sti();
            return ~2;
        }
        N r = E_mem_Q_tab_I_remove( E_windows_Q_desktop_S[ desktop_id ].window, window_id );
        E_flow_I_sti();
        return r ? ( r < ~2 ? r : ~2 ) : ~0;
    }
    *order = window_id;
    I windows = E_mem_Q_tab_R_n( E_windows_Q_desktop_S[ desktop_id ].window );
    I *stack = E_mem_Q_blk_I_append( &E_windows_Q_desktop_S[ desktop_id ].stack, 1 );
    if( !stack )
    {   if( !~(N)stack )
        {   Gk(E_mem_Q_blk_I_append( &E_windows_Q_desktop_S[ desktop_id ].stack, 1 ));
            E_flow_I_sti();
            return ~2;
        }
        N r = (N)E_mem_Q_blk_I_remove( &E_windows_Q_desktop_S[ desktop_id ].order, windows - 1, 1 );
        if( !~r
        || !r
        )
        {   if( !~(N)r )
                Gk(E_mem_Q_blk_I_append( &E_windows_Q_desktop_S[ desktop_id ].order, 1 ));
            E_flow_I_sti();
            return ~2;
        }
        r = E_mem_Q_tab_I_remove( E_windows_Q_desktop_S[ desktop_id ].window, window_id );
        E_flow_I_sti();
        return r ? ( r < ~2 ? r : ~2 ) : ~0;
    }
    *stack = window_id;
    struct E_window_Q_window_Z *window = E_mem_Q_tab_R( E_windows_Q_desktop_S[ desktop_id ].window, window_id );
    window->title = E_text_Z_s0_M_duplicate(title);
    if( !window->title )
    {   N r = (N)E_mem_Q_blk_I_remove( &E_windows_Q_desktop_S[ desktop_id ].stack, window_id, 1 );
        if( !~r
        || !r
        )
        {   if( !~(N)r )
                Gk(E_mem_Q_blk_I_append( &E_windows_Q_desktop_S[ desktop_id ].stack, 1 ));
            E_flow_I_sti();
            return ~2;
        }
        r = (N)E_mem_Q_blk_I_remove( &E_windows_Q_desktop_S[ desktop_id ].order, windows - 1, 1 );
        if( !~r
        || !r
        )
        {   if( !~(N)order )
                Gk(E_mem_Q_blk_I_append( &E_windows_Q_desktop_S[ desktop_id ].order, 1 ));
            E_flow_I_sti();
            return ~2;
        }
        r = E_mem_Q_tab_I_remove( E_windows_Q_desktop_S[ desktop_id ].window, window_id );
        E_flow_I_sti();
        return r ? ( r < ~2 ? r : ~2 ) : ~0;
    }
    window->description = E_text_Z_s0_M_duplicate(description);
    if( !window->description )
    {   N r = W( window->title );
        if( (S)r < 0 )
        {   E_flow_I_sti();
            return r < ~2 ? r : ~2;
        }
        r = (N)E_mem_Q_blk_I_remove( &E_windows_Q_desktop_S[ desktop_id ].stack, window_id, 1 );
        if( !~r
        || !r
        )
        {   if( !~(N)stack )
                Gk(E_mem_Q_blk_I_append( &E_windows_Q_desktop_S[ desktop_id ].stack, 1 ));
            E_flow_I_sti();
            return ~2;
        }
        r = (N)E_mem_Q_blk_I_remove( &E_windows_Q_desktop_S[ desktop_id ].order, windows - 1, 1 );
        if( !~r
        || !r
        )
        {   if( !~(N)order )
                Gk(E_mem_Q_blk_I_append( &E_windows_Q_desktop_S[ desktop_id ].order, 1 ));
            E_flow_I_sti();
